NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=beastops
DB_USER=postgres
DB_PASSWORD=change-me

JWT_SECRET=change-me
JWT_EXPIRES_IN=24h

# 64 hex chars (32 bytes) or base64-encoded 32-byte key.
TOKEN_ENCRYPTION_KEY=

FRONTEND_URL=http://localhost:5173

SUPERUSER_EMAIL=admin@beastops.com
BACKUP_SUPERUSER_EMAIL=backupadmin@beastops.com

# Google OAuth (required for /auth/google and callback flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Optional services
EMAIL_USER=
EMAIL_PASS=""
EMAIL_FROM=
EMAIL_SUBJECT_PREFIX=[BeastOps]
REDIS_URL=redis://localhost:6379