generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  ADMIN
  CREATOR
  EDITOR
  VIEWER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum SystemAccountType {
  NONE
  SUPERUSER
  BACKUP_SUPERUSER
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum OnboardingStatus {
  PENDING_EMAIL_VERIFICATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum AccessLevel {
  LEVEL0
  LEVEL1
  LEVEL2
  LEVEL3
  LEVEL4
  LEVEL5
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  INVITE
  BACKUP_SUPERADMIN_ACTIVATION
  PASSWORD_RESET
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String?
  name      String?
  imageUrl  String?
  /// Immutable elevated accounts; cannot be deleted, deactivated, or edited via API.
  systemAccount SystemAccountType @default(NONE)
  /// When false, user cannot authenticate (system accounts are always treated as active).
  isActive      Boolean           @default(true)
  lastLoginAt   DateTime?
  emailVerifiedAt DateTime?
  onboardingStatus OnboardingStatus @default(PENDING_EMAIL_VERIFICATION)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    WorkspaceMember[]
  tenantMemberships TenantMember[]
  createdTenants Tenant[] @relation("TenantCreator")
  approvedTenantMembers TenantMember[] @relation("TenantMemberApprover")
  issuedAuthTokens AuthToken[] @relation("AuthTokenIssuer")
  authTokens     AuthToken[]
  oauthAccounts  OAuthAccount[]
  tasksAssigned  Task[]            @relation("TaskAssignee")
  comments       Comment[]
  auditEvents    AuditEvent[]
}

model Tenant {
  id          String       @id @default(cuid())
  tenantCode  String       @unique
  companyName String
  status      TenantStatus @default(PENDING)
  createdByUserId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  createdBy   User?        @relation("TenantCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  workspaces  Workspace[]
  members     TenantMember[]
  departments Department[]
  roles       Role[]
  permissions Permission[]
  authTokens  AuthToken[]
}

model Workspace {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  members         WorkspaceMember[]
  pipelineStages  PipelineStage[]
  videoProjects   VideoProject[]
  ideas           Idea[]
  tasks           Task[]
  comments        Comment[]
  auditEvents     AuditEvent[]
  channels        Channel[]
  youtubeVideos   Video[]
  tenantMembers   TenantMember[]

  @@index([tenantId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  moduleAccess Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members TenantMember[]
  roles   Role[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TenantMember {
  id                   String           @id @default(cuid())
  tenantId             String
  userId               String
  workspaceId          String?
  departmentId         String?
  onboardingStatus     OnboardingStatus @default(PENDING_EMAIL_VERIFICATION)
  accessLevel          AccessLevel      @default(LEVEL5)
  isPrimarySuperadmin  Boolean          @default(false)
  isBackupSuperadmin   Boolean          @default(false)
  approvedByUserId     String?
  approvedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  approvedBy  User?       @relation("TenantMemberApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  roles       UserRoleAssignment[]

  @@unique([tenantId, userId])
  @@index([workspaceId])
  @@index([departmentId])
}

model Role {
  id            String   @id @default(cuid())
  tenantId      String
  departmentId  String?
  name          String
  roleKey       String?
  description   String?
  templateLevel Int?
  isSystem      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department      Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  rolePermissions RolePermission[]
  assignments     UserRoleAssignment[]

  @@index([tenantId])
  @@index([departmentId])
  @@unique([tenantId, name])
}

model Permission {
  id          String   @id @default(cuid())
  tenantId    String?
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([tenantId, resource, action])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  effect       String   @default("allow")
  conditions   Json?
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRoleAssignment {
  id             String   @id @default(cuid())
  tenantMemberId String
  roleId         String
  createdAt      DateTime @default(now())

  tenantMember TenantMember @relation(fields: [tenantMemberId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantMemberId, roleId])
}

model AuthToken {
  id             String       @id @default(cuid())
  tokenHash      String       @unique
  type           AuthTokenType
  userId         String?
  tenantId       String?
  issuedByUserId String?
  email          String?
  payload        Json?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime     @default(now())

  user       User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issuedBy   User?   @relation("AuthTokenIssuer", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([email, type])
  @@index([tenantId, type])
}

model PipelineStage {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  sortOrder   Int
  createdAt   DateTime @default(now())

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videoProjects VideoProject[]

  @@index([workspaceId, sortOrder])
}

model Idea {
  id                  String   @id @default(cuid())
  workspaceId         String
  title               String
  hooks               String?
  thumbnailConcepts   String?
  tags                String[] @default([])
  expectedPerformance String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videoProject VideoProject?
}

model VideoProject {
  id          String   @id @default(cuid())
  workspaceId String
  stageId     String
  title       String
  ideaId      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stage     PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  idea      Idea?         @relation(fields: [ideaId], references: [id])
  tasks     Task[]
  comments  Comment[]
  audits    AuditEvent[]

  @@index([workspaceId, stageId])
}

model Task {
  id             String       @id @default(cuid())
  workspaceId    String
  videoProjectId String?
  assigneeId     String?
  title          String
  dueDate        DateTime?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videoProject VideoProject? @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)
  assignee     User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments     Comment[]

  @@index([workspaceId])
  @@index([videoProjectId])
}

model Comment {
  id             String   @id @default(cuid())
  workspaceId    String
  videoProjectId String?
  taskId         String?
  authorId       String
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videoProject VideoProject? @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)
  task         Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author       User          @relation(fields: [authorId], references: [id])

  @@index([workspaceId])
}

model AuditEvent {
  id             String   @id @default(cuid())
  workspaceId    String
  videoProjectId String?
  actorId        String?
  action         String
  payload        Json?
  createdAt      DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videoProject VideoProject? @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)
  actor        User?         @relation(fields: [actorId], references: [id])

  @@index([workspaceId, createdAt])
}

model OAuthAccount {
  id                    String    @id @default(cuid())
  userId                String
  provider              String
  providerAccountId     String
  refreshTokenEncrypted String?
  accessTokenEncrypted  String?
  expiresAt             DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Channel {
  id               String   @id @default(cuid())
  workspaceId      String
  youtubeChannelId String   @unique
  title            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videos    Video[]

  @@index([workspaceId])
}

model Video {
  id             String    @id @default(cuid())
  workspaceId    String
  channelId      String
  youtubeVideoId String
  title          String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  metricsTs MetricTimeseries[]
  snapshot  MetricSnapshot?

  @@unique([workspaceId, youtubeVideoId])
  @@index([workspaceId, youtubeVideoId])
}

model MetricTimeseries {
  id           String   @id @default(cuid())
  videoId      String
  date         DateTime @db.Date
  views        Int      @default(0)
  impressions  Int?
  ctr          Float?
  watchTimeSec Int?

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, date])
  @@index([videoId, date])
}

model MetricSnapshot {
  id           String   @id @default(cuid())
  videoId      String   @unique
  views        Int      @default(0)
  impressions  Int?
  ctr          Float?
  watchTimeSec Int?
  updatedAt    DateTime @updatedAt

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}
